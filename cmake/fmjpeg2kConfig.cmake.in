@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(DCMTK CONFIG)
find_dependency(OpenJPEG)

set(fmjpeg2k_BUILD_SHARED_LIBS "@BUILD_SHARED_LIBS@")

include("${CMAKE_CURRENT_LIST_DIR}/fmjpeg2kTargets.cmake")

# Backward-compatible variables for projects that do not use target_link_libraries(... fmjpeg2k).
set(fmjpeg2k_FOUND TRUE)

set(FMJPEG2K_LIBRARIES fmjpeg2k)
set(fmjpeg2k_LIBRARIES fmjpeg2k)

set(FMJPEG2K_INCLUDE_DIRS "${PACKAGE_PREFIX_DIR}/include")
set(fmjpeg2k_INCLUDE_DIRS "${PACKAGE_PREFIX_DIR}/include")

if(NOT fmjpeg2k_BUILD_SHARED_LIBS)
  set(FMJPEG2K_DEFINITIONS FMJPEG2K_STATIC OPJ_STATIC)
  set(fmjpeg2k_DEFINITIONS FMJPEG2K_STATIC OPJ_STATIC)
else()
  set(FMJPEG2K_DEFINITIONS)
  set(fmjpeg2k_DEFINITIONS)
endif()

if(TARGET fmjpeg2k AND NOT TARGET fmjpeg2k::fmjpeg2k)
  add_library(fmjpeg2k::fmjpeg2k ALIAS fmjpeg2k)
endif()

check_required_components(fmjpeg2k)

message(STATUS "Found fmjpeg2k: ${FMJPEG2K_LIBRARIES}")
